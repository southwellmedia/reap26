---
/**
 * HomeLayout
 * Layout for the Reap Capital marketing homepage: bespoke fixed nav and
 * footer (ReapHeader/ReapFooter) instead of the standard Velocity chrome,
 * plus the scroll-reveal / count-up interactions ported from the design kit.
 */
import BaseLayout from './BaseLayout.astro';
import ReapHeader from '@/components/layout/ReapHeader.astro';
import ReapFooter from '@/components/layout/ReapFooter.astro';
import '@/styles/reap-home.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  /** Nav chrome: 'dark' over olive heroes (default), 'light' for reading pages. */
  navVariant?: 'dark' | 'light';
  /** Passed through to BaseLayout for article OG/schema markup (blog posts). */
  article?: {
    publishedTime: Date;
    modifiedTime?: Date;
    authors: string[];
    tags: string[];
  };
}

const { title, description, image, imageAlt, navVariant = 'dark', article } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} imageAlt={imageAlt} article={article} includeOrgSchema={true}>
  <ReapHeader slot="header" variant={navVariant} />

  <div class="reap-home">
    <slot />
  </div>

  <ReapFooter slot="footer" />
</BaseLayout>

<script>
  // Homepage interactions. Re-runs on astro:page-load (view transitions); the
  // AbortController tears down the previous page's listeners first.
  let controller: AbortController | undefined;

  function initReapHome() {
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    // Hero video: honor reduced-motion (poster stays as the still fallback)
    const heroVideo = document.querySelector<HTMLVideoElement>('.hero video, video.hero-bg');
    if (heroVideo && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      heroVideo.removeAttribute('autoplay');
      heroVideo.pause();
    }

    // Nav: transparent over hero → solid after scroll
    const nav = document.querySelector('.reap-nav');
    if (nav) {
      const onScroll = () => nav.classList.toggle('solid', window.scrollY > 60);
      window.addEventListener('scroll', onScroll, { passive: true, signal });
      onScroll();
    }

    // Mobile disclosure menu
    const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
    const menu = document.querySelector<HTMLElement>('.nav-menu');
    if (toggle && menu && nav) {
      const setOpen = (open: boolean) => {
        menu.hidden = !open;
        toggle.setAttribute('aria-expanded', String(open));
        toggle.textContent = open ? 'Close' : 'Menu';
        nav.classList.toggle('menu-open', open);
      };
      toggle.addEventListener('click', () => setOpen(menu.hidden), { signal });
      menu.addEventListener(
        'click',
        (e) => {
          if ((e.target as HTMLElement).closest('a')) setOpen(false);
        },
        { signal }
      );
    }

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Scroll reveals: structural units rise in as they enter; grid children
    // stagger. Everything stays visible when JS is absent (html.js-rvl gate)
    // or when the visitor prefers reduced motion (we never tag .rvl).
    if (!reduceMotion && 'IntersectionObserver' in window) {
      document.documentElement.classList.add('js-rvl');

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('rvl-in');
              io.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
      );
      signal.addEventListener('abort', () => io.disconnect());

      const prep = (el: Element, delay = 0) => {
        el.classList.add('rvl');
        if (delay) (el as HTMLElement).style.setProperty('--rvl-delay', `${delay}ms`);
        io.observe(el);
      };

      document
        .querySelectorAll(
          '.reap-home .sec-head, .reap-home .block .split, .reap-home .firm-visual, .reap-home .port-head, .reap-home .feature, .reap-home .prop-index, .reap-home .team-lead, .reap-home .perspectives-note, .reap-home .testimonial-split, .reap-home .cta-in'
        )
        .forEach((el) => prep(el));

      // siblings inside a grid/ledger cascade at 70ms, capped so late rows
      // scrolled to directly don't sit idle
      const siblingCount = new Map<Element, number>();
      document
        .querySelectorAll(
          '.reap-home .rule-list > *, .reap-home .values-grid > *, .reap-home .cols3 > *, .reap-home .props > *, .reap-home .team-grid > *, .reap-home .article'
        )
        .forEach((el) => {
          const parent = el.parentElement as Element;
          const i = siblingCount.get(parent) ?? 0;
          siblingCount.set(parent, i + 1);
          prep(el, Math.min(i * 70, 280));
        });
    }

    // Stat count-up: ticker figures tally to their real values on entry.
    // The rendered HTML already holds the final number — reduced motion and
    // no-JS visitors simply see it as-is.
    if (!reduceMotion && 'IntersectionObserver' in window) {
      const countUp = (el: HTMLElement) => {
        const original = el.textContent?.trim() ?? '';
        const m = original.match(/^([^0-9]*)([\d,]+(?:\.\d+)?)([^0-9]*)$/);
        if (!m) return;
        const target = parseFloat(m[2].replace(/,/g, ''));
        const decimals = (m[2].split('.')[1] ?? '').length;
        const grouped = m[2].includes(',');
        const start = performance.now();
        const dur = 1500;
        const step = (now: number) => {
          if (signal.aborted) {
            el.textContent = original;
            return;
          }
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 5);
          const v = target * eased;
          el.textContent =
            t >= 1
              ? original
              : m[1] + (grouped ? Math.round(v).toLocaleString('en-US') : v.toFixed(decimals)) + m[3];
          if (t < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };

      const statIo = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              statIo.unobserve(entry.target);
              countUp(entry.target as HTMLElement);
            }
          }
        },
        { threshold: 0.5 }
      );
      signal.addEventListener('abort', () => statIo.disconnect());
      document
        .querySelectorAll<HTMLElement>('.reap-home .ticker .n')
        .forEach((el) => statIo.observe(el));
    }
  }

  document.addEventListener('astro:page-load', initReapHome);
</script>
