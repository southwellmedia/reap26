---
/**
 * BlogLayout — Perspectives article
 * Printed-memo article page on the brand chrome: light ReapHeader, gold
 * eyebrow + Playfair title over white, hero photo under the olive tint,
 * case-body prose, then a "More Perspectives" ledger and the Invest CTA.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import HomeLayout from './HomeLayout.astro';
import InvestCta from '@/components/home/InvestCta.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { createBreadcrumbSchema } from '@/lib/schema';
import siteConfig from '@/config/site.config';
import { firmStats, PERFORMANCE_DISCLOSURE } from '@/config/stats.config';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  tags?: string[];
  slug?: string;
  /** Minutes, computed from the actual article body by the calling page. */
  readingTime?: number;
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author = 'Reap Capital',
  image,
  imageAlt,
  tags = [],
  slug = '',
  readingTime,
} = Astro.props;

const ogImage = image?.src || `/og${Astro.url.pathname}.png`;
const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();

const breadcrumbSchema = createBreadcrumbSchema([
  { name: 'Home', url: siteConfig.url },
  { name: 'Perspectives', url: new URL('/blog', siteConfig.url).toString() },
  { name: title, url: fullUrl },
]);

// Frontmatter dates are UTC midnights — format in UTC so the day never slips.
const fullDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });

// Latest other entries for the closing ledger — recency, not tag overlap,
// so every article leads somewhere even while the archive is small.
const morePosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((post) => post.id !== slug)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<HomeLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
  navVariant="light"
  article={{
    publishedTime: publishedAt,
    modifiedTime: updatedAt,
    authors: [author],
    tags,
  }}
>
  <JsonLd schema={breadcrumbSchema} />

  <article>
    <header class="post-hero">
      <div class="wrap">
        <div class="post-head">
          <a class="back-link on-light" href="/blog">⟵ All Perspectives</a>
          <span class="eyebrow">{tags[0] ?? 'Field Notes'}</span>
          <h1 class="display post-title">{title}</h1>
          <p class="post-lede">{description}</p>
          <div class="post-meta">
            <span>{author}</span>
            <time datetime={publishedAt.toISOString()}>{fullDate(publishedAt)}</time>
            {updatedAt && (
              <time datetime={updatedAt.toISOString()}>Updated {fullDate(updatedAt)}</time>
            )}
            {readingTime && <span>{readingTime} min read</span>}
          </div>
        </div>
        {image && (
          <figure class="post-figure">
            <Image
              src={image}
              alt={imageAlt || ''}
              widths={[640, 960, 1280, 1920]}
              sizes="(max-width: 1360px) 100vw, 1232px"
              loading="eager"
            />
          </figure>
        )}
      </div>
    </header>

    <div class="wrap">
      <div class="case-layout post-layout">
        <div>
          <div class="case-body post-body">
            <slot />
          </div>

          <footer class="post-foot">
            <a class="back-link on-light" href="/blog">⟵ All Perspectives</a>
            <ShareButtons title={title} url={fullUrl} />
          </footer>
        </div>

        <aside class="case-aside post-aside">
          <div class="case-facts">
            <span class="eyebrow on-dark">The Operator</span>
            <dl>
              <div class="row">
                <dt>Avg Realized IRR</dt>
                <dd>{firmStats.avgIrr}</dd>
              </div>
              <div class="row">
                <dt>Assets Under Mgmt</dt>
                <dd>{firmStats.aum}</dd>
              </div>
              <div class="row">
                <dt>Units Sponsored</dt>
                <dd>{firmStats.unitsSponsored}</dd>
              </div>
              <div class="row">
                <dt>Full-Cycle Exits</dt>
                <dd>{firmStats.fullCycle}</dd>
              </div>
            </dl>
            <a class="btn gold" href="/invest">Request Access <span aria-hidden="true">⟶</span></a>
            <p class="facts-disclosure">{PERFORMANCE_DISCLOSURE}</p>
          </div>
        </aside>
      </div>
    </div>
  </article>

  {
    morePosts.length > 0 && (
      <section class="post-more">
        <div class="wrap">
          <div class="sec-head">
            <span class="eyebrow">More Perspectives</span>
          </div>
          <div style="margin-top:40px">
            {morePosts.map((post) => (
              <a class="article" href={`/blog/${post.id}`}>
                <span class="cat">{post.data.tags?.[0] ?? 'Field Notes'}</span>
                <h3>{post.data.title}</h3>
                <span class="date">{fullDate(post.data.publishedAt)}</span>
                <span class="arr" aria-hidden="true">⟶</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <InvestCta perspectivesHref="/blog" />
</HomeLayout>
