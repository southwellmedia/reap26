---
/**
 * /invest — Request Access
 * A standalone split-view experience, not a site page: full-height olive
 * brand panel (photo, watermark, stats, LP quote) beside a focused light
 * conversion column. No site nav or footer — the only exits are the brand
 * link home and the email fallback. The form registers the prospect with
 * LucidOS (the same key-less interest endpoint the homepage OfferModal and
 * OfferingsGate use), stores the 30-day deal-room token, and redirects into
 * the room. When no raise is active the form defers to the email fallback —
 * nothing posts to /api/contact (a stub that stores nothing).
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/reap-home.css';
import towers from '@/assets/reap/towers-dusk.jpg';
import watermark from '@/assets/reap/reap-watermark.svg';
import logomark from '@/assets/reap/reap-logomark-gold.svg';
import { firmStats, PERFORMANCE_DISCLOSURE } from '@/config/stats.config';
import { DEALROOM_BASE_URL } from '@/lib/dealroom';

const steps = [
  {
    num: '01',
    title: 'Request access',
    body: 'Tell us who you are and what you want your capital to do. We reply within two business days.',
  },
  {
    num: '02',
    title: 'Talk to the operators',
    body: 'A direct conversation with the team that underwrites, builds, and manages every asset — no salespeople in between.',
  },
  {
    num: '03',
    title: 'Review what is open',
    body: 'Current offerings with the underwriting, business plan, and terms laid out deal by deal.',
  },
];
---

<BaseLayout
  title="Invest With Us"
  description="Request access to Reap Capital's current offerings — a vertically integrated, value-add multifamily operator with a 34.25% average realized IRR since inception."
>
  <div class="reap-home invest-page" style={`--invest-photo: url('${towers.src}')`}>
    <aside class="invest-brand-panel">
      <div class="photo"></div>
      <div class="scrim"></div>
      <img class="watermark" src={watermark.src} alt="" />
      <div class="invest-brand-in">
        <a class="invest-brand-link" href="/">
          <img src={logomark.src} width="40" height="40" alt="" />
          <span>
            <span class="name">Reap Capital</span>
            <span class="back"><span aria-hidden="true">⟵</span> Back to the firm</span>
          </span>
        </a>

        <div class="invest-brand-copy">
          <span class="eyebrow on-dark">Invest With Us</span>
          <h1 class="display">Put disciplined operators<br /><em>behind your capital.</em></h1>
          <p>
            We allow sophisticated investors — accredited or not — to participate in our offerings.
            The same team that underwrites each deal renovates it, operates it, and reports to you.
          </p>
        </div>

        <div class="invest-brand-foot">
          <div class="invest-stats">
            <div>
              <div class="n">{firmStats.avgIrr}</div>
              <div class="l">Avg. Realized IRR</div>
            </div>
            <div>
              <div class="n">{firmStats.aum}</div>
              <div class="l">Assets Under Mgmt.</div>
            </div>
            <div>
              <div class="n">{firmStats.fullCycle}</div>
              <div class="l">Full-Cycle Deals</div>
            </div>
          </div>
          <blockquote class="invest-quote">
            <p>
              “I have never been more pleased, nor more impressed, with my investments with Reap
              Capital. Reap Capital has earned a lifelong customer with myself and my family.”
            </p>
            <footer>Casey P. Cook · Reap Capital Investor</footer>
          </blockquote>
        </div>
      </div>
    </aside>

    <section class="invest-form-panel">
      <div class="invest-form-inner">
        <div class="invest-form-head">
          <span class="eyebrow">Request Access</span>
          <h2 class="display display-2">Three steps from <em>here to allocated.</em></h2>
        </div>

        <ol class="next-steps">
          {
            steps.map((step) => (
              <li>
                <span class="num">{step.num}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </div>
              </li>
            ))
          }
        </ol>

        <form class="invest-form on-light" data-api-base={DEALROOM_BASE_URL} novalidate>
          <div class="field">
            <label for="ra-name">Name</label>
            <input id="ra-name" name="fullName" type="text" autocomplete="name" required minlength="2" maxlength="200" />
          </div>
          <div class="field">
            <label for="ra-email">Email</label>
            <input id="ra-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="ra-status">Investor Status</label>
            <select id="ra-status" name="investorStatus">
              <option value="Accredited investor">Accredited investor</option>
              <option value="Non-accredited (sophisticated) investor">Non-accredited (sophisticated)</option>
              <option value="Not sure yet">Not sure yet</option>
            </select>
          </div>
          <div class="field">
            <label for="ra-range">Investment Range <span class="opt">(optional)</span></label>
            <select id="ra-range" name="investmentRange">
              <option value="">Prefer not to say</option>
              <option value="Under $50k">Under $50k</option>
              <option value="$50k – $100k">$50k – $100k</option>
              <option value="$100k – $250k">$100k – $250k</option>
              <option value="$250k – $500k">$250k – $500k</option>
              <option value="$500k+">$500k+</option>
            </select>
          </div>
          <div class="field field-wide">
            <label for="ra-message">Your Goals</label>
            <textarea
              id="ra-message"
              name="message"
              rows="4"
              required
              minlength="10"
              placeholder="Timeline, target allocation, questions — whatever helps us point you at the right offering."></textarea>
          </div>
          <div class="field field-wide form-actions">
            <button class="btn gold" type="submit">Request Access <span aria-hidden="true">⟶</span></button>
            <a class="alt-path" href="mailto:info@reapcap.com">or email info@reapcap.com</a>
          </div>
          <p class="form-status field-wide" role="status" aria-live="polite"></p>
        </form>

        <p class="invest-disclosure">{PERFORMANCE_DISCLOSURE}</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  // Request-access form → LucidOS interest endpoint (same flow as OfferModal):
  // register the prospect, store the deal-room token, redirect into the room.
  const ACCESS_KEY = 'reap:dealroom-access';

  async function initInvestForm() {
    const form = document.querySelector<HTMLFormElement>('.invest-form');
    if (!form || form.dataset.wired) return;
    form.dataset.wired = 'true';
    const status = form.querySelector<HTMLElement>('.form-status');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    let raiseId: string | null = null;
    try {
      const res = await fetch('/api/dealroom-status');
      const state = res.ok ? await res.json() : null;
      if (state?.active && state.raiseId) raiseId = state.raiseId;
    } catch {
      /* status route unreachable — treated below as no active raise */
    }

    // No active raise: the interest endpoint needs a raiseId, and /api/contact
    // is a stub that stores nothing — email is the only path that reaches us.
    if (!raiseId) {
      if (button) button.disabled = true;
      if (status) {
        status.textContent =
          'Requests are handled directly right now — email info@reapcap.com and we’ll reply within two business days.';
      }
      return;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      if (button) button.disabled = true;
      if (status) {
        status.classList.remove('error');
        status.textContent = 'One moment…';
      }

      const data = new FormData(form);
      const payload: Record<string, string> = { sourceUrl: location.href };
      for (const key of ['fullName', 'email', 'investmentRange']) {
        const value = data.get(key)?.toString().trim();
        if (value) payload[key] = value;
      }
      const investorStatus = data.get('investorStatus')?.toString().trim();
      const goals = data.get('message')?.toString().trim();
      payload.message = [
        'Request access (/invest)',
        investorStatus ? `Investor status: ${investorStatus}` : null,
        goals ? `Goals: ${goals}` : null,
      ]
        .filter(Boolean)
        .join(' — ')
        .slice(0, 5000);

      const setError = (text: string) => {
        if (status) {
          status.classList.add('error');
          status.textContent = text;
        }
        if (button) button.disabled = false;
      };

      // Same rule as the deal-room gate: no prospect registered, no entry
      try {
        const res = await fetch(`${form.dataset.apiBase}/v1/raises/${raiseId}/interest`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          if (res.status === 429) {
            setError('Too many requests from your connection — try again in an hour, or email info@reapcap.com.');
          } else {
            const body = await res.json().catch(() => null);
            setError(
              body?.error
                ? `We couldn’t register your request: ${body.error}`
                : 'We couldn’t register your request — please email info@reapcap.com for access.'
            );
          }
          return;
        }
      } catch {
        setError(
          'We couldn’t reach the registration service — an ad blocker may be interfering. Please retry or email info@reapcap.com.'
        );
        return;
      }
      try {
        localStorage.setItem(ACCESS_KEY, String(Date.now()));
      } catch {
        /* private mode — the deal-room gate will ask again */
      }
      window.location.assign(`/offerings/${raiseId}`);
    });
  }

  document.addEventListener('astro:page-load', initInvestForm);
</script>
