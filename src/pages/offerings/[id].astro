---
/**
 * Deal room — /offerings/[id]
 * A standalone split-view experience, not a site page (same grammar as
 * /invest): a sticky olive sidebar carrying the deal's identity — cover
 * photo, name, target metrics, funding progress, terms — beside a light
 * scrolling column with the narrative, property profile, and interest form.
 * No site nav or footer; the exits are the brand link and /offerings.
 *
 * Gated and unlisted: OfferingsGate self-certification interstitial,
 * noindex + X-Robots-Tag, no nav link — links are shared through the
 * /invest request-access flow. Server-rendered from GET /v1/raises/{id}
 * (see LUCID-DEALROOM.md) with a 60s CDN cache; the payload is teaser-tier
 * by design (no documents, financials, or street address). A hidden or
 * unknown raise 404s to the branded "no longer available" state.
 */
import { marked } from 'marked';
import BaseLayout from '@/layouts/BaseLayout.astro';
import OfferingsGate from '@/components/patterns/OfferingsGate.astro';
import '@/styles/reap-home.css';
import logomark from '@/assets/reap/reap-logomark-gold.svg';
import watermark from '@/assets/reap/reap-watermark.svg';
import {
  getTeaser,
  formatMoney,
  formatPercent,
  formatMultiple,
  formatCloseDate,
  cadenceLabel,
  locationLabel,
  toEmbedUrl,
  DEALROOM_BASE_URL,
  INVESTOR_PORTAL_URL,
} from '@/lib/dealroom';

export const prerender = false;

const { id } = Astro.params;
// Raise IDs are UUIDs — anything else can skip the API round-trip
const teaser = id && /^[0-9a-f-]{36}$/i.test(id) ? await getTeaser(id) : null;
if (!teaser) return Astro.rewrite('/offerings/unavailable');

Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate');
Astro.response.headers.set('CDN-Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');

const { raise, deal, dealRoom, metrics, progress, interest } = teaser;

const isClosed = raise.status === 'closed';
const name = deal?.name ?? raise.name;
const location = locationLabel(deal);
const embedUrl = toEmbedUrl(dealRoom.videoUrl);
const summaryHtml = dealRoom.summaryMd ? marked.parse(dealRoom.summaryMd, { async: false }) : null;

const OFFERING_DISCLAIMER =
  'This is not an offer to sell securities. Offerings are made only to qualified investors through official offering documents inside the investor portal. Past performance is not indicative of future results.';

// Sidebar metrics — the return targets that define the deal
const sideMetrics: { n: string; l: string }[] = [
  { n: formatPercent(metrics?.targetIrr ?? null), l: 'Target IRR' },
  { n: formatMultiple(metrics?.targetEquityMultiple ?? null), l: 'Equity Multiple' },
  { n: formatPercent(metrics?.targetCashOnCash ?? null), l: 'Cash-on-Cash' },
  {
    n: metrics?.holdPeriodYears ?? deal?.holdPeriodYears
      ? `${metrics?.holdPeriodYears ?? deal?.holdPeriodYears} Yr`
      : null,
    l: 'Target Hold',
  },
].filter((stat): stat is { n: string; l: string } => stat.n !== null);

// Sidebar terms ledger
const terms: { label: string; value: string | null }[] = [
  { label: 'Target Raise', value: formatMoney(raise.targetRaise) },
  { label: 'Minimum Investment', value: formatMoney(raise.minimumInvestment) },
  { label: 'Distributions', value: cadenceLabel(raise.distributionCadence) },
  { label: 'Anticipated Close', value: formatCloseDate(raise.closeDate) },
];
const shownTerms = terms.filter((term) => term.value !== null);

// Property profile — the asset facts, shown in the content column
const profile: { label: string; value: string | null }[] = [
  { label: 'Location', value: location },
  { label: 'Asset Type', value: deal?.propertyType ?? null },
  { label: 'Units', value: deal?.unitCount ? String(deal.unitCount) : null },
  { label: 'Year Built', value: deal?.yearBuilt ? String(deal.yearBuilt) : null },
  {
    label: 'Square Footage',
    value: deal?.squareFootage ? deal.squareFootage.toLocaleString('en-US') : null,
  },
  { label: 'Hold Period', value: deal?.holdPeriodYears ? `${deal.holdPeriodYears} Years` : null },
];
const shownProfile = profile.filter((fact) => fact.value !== null);

const pct = progress.percentOfTarget;
---

<BaseLayout
  title={`${name} — Private Offering`}
  description={dealRoom.headline ??
    `${name} — a Reap Capital private investment offering${location ? ` in ${location}` : ''}.`}
  image={dealRoom.coverImageUrl ?? undefined}
  imageAlt={dealRoom.coverImageUrl ? name : undefined}
  noindex={true}
>
  <div
    class="reap-home dealroom-page"
    style={dealRoom.coverImageUrl ? `--dealroom-photo: url('${dealRoom.coverImageUrl}')` : undefined}
  >
    <aside class="dealroom-side">
      <div class="photo"></div>
      <div class="scrim"></div>
      <img class="watermark" src={watermark.src} alt="" />
      <div class="dealroom-side-in">
        <a class="invest-brand-link" href="/">
          <img src={logomark.src} width="40" height="40" alt="" />
          <span>
            <span class="name">Reap Capital</span>
            <span class="back">Private Offering</span>
          </span>
        </a>

        <div class="dealroom-id">
          <span class="eyebrow on-dark">
            {[isClosed ? 'Fully Subscribed' : 'Open Offering', location].filter(Boolean).join(' · ')}
          </span>
          <h1 class="display">{name}</h1>
          {dealRoom.headline && <p class="dealroom-headline">{dealRoom.headline}</p>}
        </div>

        <div class="dealroom-side-foot">
          {
            sideMetrics.length > 0 && (
              <div class="dealroom-metrics">
                {sideMetrics.map((stat) => (
                  <div>
                    <div class="n">{stat.n}</div>
                    <div class="l">{stat.l}</div>
                  </div>
                ))}
              </div>
            )
          }

          {
            pct !== null && (
              <div class="raise-progress">
                <div class="bar" role="progressbar" aria-valuenow={pct} aria-valuemin="0" aria-valuemax="100" aria-label="Funding progress">
                  <div class="fill" style={`width:${Math.min(pct, 100)}%`} />
                </div>
                <div class="legend">
                  <span>{pct}% committed</span>
                  {progress.committedCount > 0 && <span>{progress.committedCount} investors</span>}
                </div>
              </div>
            )
          }

          {
            shownTerms.length > 0 && (
              <dl class="dealroom-terms">
                {shownTerms.map((term) => (
                  <div class="row">
                    <dt>{term.label}</dt>
                    <dd>{term.value}</dd>
                  </div>
                ))}
              </dl>
            )
          }

          {
            !isClosed && (
              <a class="btn gold" href="mailto:info@reapcap.com">
                Speak With the Operators <span aria-hidden="true">⟶</span>
              </a>
            )
          }
        </div>
      </div>
    </aside>

    <main class="dealroom-main">
      <div class="dealroom-main-in">
        <div class="dealroom-head">
          <span class="eyebrow">The Opportunity</span>
          <h2 class="display display-2">
            {isClosed ? <>Executed and <em>fully subscribed.</em></> : <>The deal, <em>on its merits.</em></>}
          </h2>
        </div>

        <div class="case-body post-body">
          {summaryHtml ? <Fragment set:html={summaryHtml} /> : <p>{dealRoom.headline}</p>}
          {
            embedUrl && (
              <div class="deal-video">
                <iframe
                  src={embedUrl}
                  title={`${name} — offering video`}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              </div>
            )
          }
        </div>

        {
          shownProfile.length > 0 && (
            <div class="dealroom-profile">
              <span class="eyebrow">Property Profile</span>
              <dl>
                {shownProfile.map((fact) => (
                  <div class="row">
                    <dt>{fact.label}</dt>
                    <dd>{fact.value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )
        }

        <div class="dealroom-interest-block" id="next">
          {
            interest.enabled && !isClosed ? (
              <>
                <span class="eyebrow">What Happens Next</span>
                <h2 class="display display-2">From here to <em>allocated.</em></h2>
                <p class="interest-lede">
                  You're on the list for this offering — entering the deal room registered your
                  interest with our team. Documents, detailed financials, and soft commitments live
                  in the invite-only investor portal.
                </p>
                <ol class="next-steps">
                  <li>
                    <span class="num">01</span>
                    <div>
                      <h3>Interest registered</h3>
                      <p>
                        Your request is in our fundraising pipeline for this deal — no forms left to
                        fill out here.
                      </p>
                    </div>
                  </li>
                  <li>
                    <span class="num">02</span>
                    <div>
                      <h3>Personal follow-up</h3>
                      <p>
                        The team reaches out within two business days to answer questions and
                        confirm fit — operators, not salespeople.
                      </p>
                    </div>
                  </li>
                  <li>
                    <span class="num">03</span>
                    <div>
                      <h3>Portal invitation</h3>
                      <p>
                        You receive an invitation to the investor portal: full offering documents,
                        detailed underwriting, and the ability to soft-commit your allocation.
                      </p>
                    </div>
                  </li>
                </ol>
                <p class="interest-lede">
                  Already invited? <a class="portal-link" href={INVESTOR_PORTAL_URL}>Open the investor portal</a> —
                  or email <a class="portal-link" href="mailto:info@reapcap.com">info@reapcap.com</a> with questions.
                </p>
              </>
            ) : (
              <>
                <span class="eyebrow">Fully Subscribed</span>
                <h2 class="display display-2">This offering is <em>fully subscribed.</em></h2>
                <p class="interest-lede">
                  Every allocation in {name} has been committed. Request access and you will hear
                  about the next offering before it opens.
                </p>
                <div class="cta-actions" style="justify-content:flex-start">
                  <a class="btn line" href="/invest">Request Access <span aria-hidden="true">⟶</span></a>
                </div>
              </>
            )
          }
        </div>

        <p class="invest-disclosure">{OFFERING_DISCLAIMER}</p>
      </div>
    </main>

    <OfferingsGate
      raiseId={interest.enabled && !isClosed ? raise.id : null}
      apiBaseUrl={DEALROOM_BASE_URL}
    />
  </div>
</BaseLayout>
