---
/**
 * DealRoomInterestForm — LucidOS interest submission (LUCID-DEALROOM.md).
 * Posts JSON from the browser straight to the LucidOS endpoint; that route
 * is key-less by design, so no site API route is involved. Success is always
 * `{ ok: true }` and never reveals whether the email was already known.
 *
 * If the sponsor enables reCAPTCHA in LucidOS (teaser.interest.recaptchaSiteKey
 * becomes non-null), submissions will 400 until this component is extended to
 * send `recaptchaToken` and the site is rebuilt.
 */
interface Props {
  raiseId: string;
  apiBaseUrl: string;
  recaptchaSiteKey: string | null;
}

const { raiseId, apiBaseUrl, recaptchaSiteKey } = Astro.props;
const action = `${apiBaseUrl}/v1/raises/${raiseId}/interest`;
---

<form
  class="invest-form on-light dealroom-interest"
  method="post"
  action={action}
  data-recaptcha-site-key={recaptchaSiteKey}
  novalidate
>
  <div class="field">
    <label for="dri-name">Name</label>
    <input id="dri-name" name="fullName" type="text" autocomplete="name" required maxlength="200" />
  </div>
  <div class="field">
    <label for="dri-email">Email</label>
    <input id="dri-email" name="email" type="email" autocomplete="email" required />
  </div>
  <div class="field">
    <label for="dri-phone">Phone <span class="opt">(optional)</span></label>
    <input id="dri-phone" name="phone" type="tel" autocomplete="tel" />
  </div>
  <div class="field">
    <label for="dri-range">Investment Range <span class="opt">(optional)</span></label>
    <select id="dri-range" name="investmentRange">
      <option value="">Prefer not to say</option>
      <option value="Under $50k">Under $50k</option>
      <option value="$50k – $100k">$50k – $100k</option>
      <option value="$100k – $250k">$100k – $250k</option>
      <option value="$250k – $500k">$250k – $500k</option>
      <option value="$500k+">$500k+</option>
    </select>
  </div>
  <div class="field field-wide">
    <label for="dri-message">Questions or Notes <span class="opt">(optional)</span></label>
    <textarea
      id="dri-message"
      name="message"
      rows="4"
      maxlength="5000"
      placeholder="Timeline, allocation size, questions about the deal — anything that helps us follow up well."></textarea>
  </div>
  <div class="field field-wide form-actions">
    <button class="btn gold" type="submit">Express Interest <span aria-hidden="true">⟶</span></button>
    <a class="alt-path" href="mailto:info@reapcap.com">or email info@reapcap.com</a>
  </div>
  <p class="form-status field-wide" role="status" aria-live="polite"></p>
</form>

<script>
  // Interest form → POST directly to LucidOS (key-less endpoint, browser-safe)
  function initDealRoomInterestForms() {
    document.querySelectorAll<HTMLFormElement>('.dealroom-interest').forEach((form) => {
      if (form.dataset.wired) return;
      form.dataset.wired = 'true';
      const status = form.querySelector<HTMLElement>('.form-status');
      const setStatus = (text: string, isError = false) => {
        if (!status) return;
        status.classList.toggle('error', isError);
        status.textContent = text;
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;
        const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const data = new FormData(form);
        const payload: Record<string, string> = { sourceUrl: location.href };
        for (const key of ['fullName', 'email', 'phone', 'investmentRange', 'message']) {
          const value = data.get(key)?.toString().trim();
          if (value) payload[key] = value;
        }

        if (button) button.disabled = true;
        setStatus('Sending…');
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(payload),
          });
          if (res.ok) {
            form.reset();
            setStatus(
              'Thank you — your interest is registered. We follow up personally with deal room access.'
            );
          } else if (res.status === 429) {
            setStatus('Too many requests from your connection — please try again in an hour.', true);
          } else {
            const body = await res.json().catch(() => null);
            setStatus(
              body?.error
                ? `We couldn’t submit that: ${body.error}`
                : 'Something went wrong on our end — please email info@reapcap.com instead.',
              true
            );
          }
        } catch {
          setStatus(
            'Something went wrong on our end — please email info@reapcap.com and we’ll take it from there.',
            true
          );
        } finally {
          if (button) button.disabled = false;
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initDealRoomInterestForms);
</script>
