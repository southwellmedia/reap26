---
/**
 * ShareButtons — typed share controls in the brand grammar: square,
 * hairline-bordered, letterspaced uppercase. No logos, no brand-blue fills;
 * the copy control confirms (or reports failure) by swapping its label.
 */
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

const shareLinks = {
  x: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
};
---

<div class="share-row">
  <span class="share-label">Share</span>
  <a class="share-btn" href={shareLinks.x} target="_blank" rel="noopener noreferrer">X</a>
  <a class="share-btn" href={shareLinks.linkedin} target="_blank" rel="noopener noreferrer">
    LinkedIn
  </a>
  <button type="button" class="share-btn copy-link-btn" data-url={url} aria-live="polite">
    Copy Link
  </button>
</div>

<script>
  function initShareButtons() {
    document.querySelectorAll<HTMLButtonElement>('.copy-link-btn').forEach((button) => {
      button.addEventListener('click', async () => {
        const url = button.getAttribute('data-url');
        if (!url) return;

        const reset = (label: string) => {
          button.textContent = label;
          button.classList.add('copied');
          setTimeout(() => {
            button.textContent = 'Copy Link';
            button.classList.remove('copied');
          }, 2000);
        };

        try {
          await navigator.clipboard.writeText(url);
          reset('Copied');
        } catch {
          reset('Copy Failed');
        }
      });
    });
  }

  initShareButtons();
  document.addEventListener('astro:page-load', initShareButtons);
</script>
