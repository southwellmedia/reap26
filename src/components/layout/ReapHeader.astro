---
/**
 * ReapHeader
 * Fixed site nav: transparent over the hero, solid olive after scroll
 * (the `.solid` class is toggled by the script in HomeLayout, which also
 * drives the mobile disclosure menu).
 */
import { getNavItems } from '@/config/nav.config';
import logomark from '@/assets/reap/reap-logomark-gold.svg';

interface Props {
  /** 'dark' (default) is transparent over olive heroes; 'light' is the
   *  white-paper chrome for reading pages (Perspectives). */
  variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;
const navItems = getNavItems();

// Current-page marker for path-based nav items (anchor links never match).
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (href: string) => {
  if (href.startsWith('/#') || href === '/') return false;
  const path = href.replace(/\/$/, '');
  return currentPath === path || currentPath.startsWith(`${path}/`);
};
---

<header class:list={['reap-nav', { light: variant === 'light' }]}>
  <div class="nav-in">
    <a class="brand" href="/#top">
      <img class="brand-mark" src={logomark.src} width="44" height="44" alt="" />
      <span>
        <span class="brand-name">Reap Capital</span>
        <span class="brand-tag">Real Estate • Private Equity</span>
      </span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
      <a href="/invest" class="btn">Invest With Us</a>
    </nav>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="reap-menu">Menu</button>
  </div>
  <nav class="nav-menu" id="reap-menu" aria-label="Primary" hidden>
    {navItems.map((item) => (
      <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
        {item.label}
      </a>
    ))}
    <a href="/invest" class="btn gold">Invest With Us</a>
  </nav>
</header>
<script is:inline>
  // Solid state before first paint — the scroll listener in HomeLayout only
  // runs after hydration, which flashed white-on-white on anchor jumps and
  // mid-page loads over light sections.
  if (window.scrollY > 60) document.querySelector('.reap-nav')?.classList.add('solid');
</script>
