---
/**
 * ReapFooter
 * Deep-ink footer with wordmark, link columns, and legal strap.
 */
import wordmark from '@/assets/reap/reap-wordmark-white.png';

const year = new Date().getFullYear();
---

<footer class="reap-footer">
  <div class="foot">
    <div>
      <img src={wordmark.src} width="200" height={Math.round((wordmark.height / wordmark.width) * 200)} alt="Reap Capital" class="wordmark" loading="lazy" />
      <p>
        An IRR-driven, vertically integrated, value-add operator based in Dallas–Fort Worth.
        Recognize opportunity. Reap Capital.
      </p>
    </div>
    <div>
      <h2>Firm</h2>
      <a href="/#firm">About</a>
      <a href="/#method">Method</a>
      <a href="/track-record">Track Record</a>
      <a href="/#team">Team</a>
      <a href="/blog">Perspectives</a>
    </div>
    <div>
      <h2>Investors</h2>
      <a href="/invest">Current Offerings</a>
      <a href="/invest">Request Access</a>
      <a href="/invest">Investor Signup</a>
      <a href="https://invest.reapcap.com">Investor Login</a>
    </div>
    <div>
      <h2>Contact</h2>
      <span class="plain">12770 Merit Dr. Suite 850<br />Dallas, TX 75251</span>
      <a href="tel:+18667327123">1-866-REAP-123</a>
      <a href="mailto:info@reapcap.com">info@reapcap.com</a>
    </div>
  </div>
  <div class="legal">
    <span>© {year} Reap Capital. All rights reserved.</span>
    <span class="strap">Real Estate • Private Equity • Investing</span>
  </div>
</footer>
