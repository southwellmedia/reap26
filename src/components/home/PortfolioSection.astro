---
/**
 * PortfolioSection
 * "Track Record" — data verified against reapcapital.com/track-record.
 * Featured active deal (The Landry) + three full-cycle highlight cards,
 * then the complete property index as a compact thumbnail ledger.
 */
import { Image } from 'astro:assets';
import SectionHead from './SectionHead.astro';
import apartment from '@/assets/reap/apartment-blue.jpg';
import towers from '@/assets/reap/towers-dusk.jpg';
import skyline from '@/assets/reap/dallas-skyline.jpg';
import aerial from '@/assets/reap/hero-aerial-olive.webp';

const highlights = [
  {
    image: towers,
    alt: 'Sierra Heights',
    meta: 'Full Cycle · Irving, TX',
    name: 'Sierra Heights',
    blurb: '136 units taken full cycle in 25 months — a 37.24% actual IRR and 1.86x equity multiple.',
  },
  {
    image: skyline,
    alt: 'Liberty Park',
    meta: 'Full Cycle · Dallas, TX',
    name: 'Liberty Park',
    blurb: '67 units bought direct from the seller as a stabilized high-yield play — 49% actual IRR, 2.05x in 23 months.',
  },
  {
    image: aerial,
    alt: 'Hwy 380 Self Storage',
    meta: 'Full Cycle · Texas',
    name: 'Hwy 380 Self Storage',
    blurb: 'A mismanaged facility at 16% occupancy, rebuilt into a 61.49% actual IRR and 2.90x in 27 months.',
  },
];

const index = [
  { image: apartment, name: 'The Haven', meta: 'San Antonio, TX', figure: 'Active · Target IRR 18–21%' },
  { image: skyline, name: 'The Bryant', meta: 'Dallas, TX · 322 Units', figure: 'Active · Target IRR 19–21%' },
  { image: towers, name: 'The Charlie', meta: 'Dallas, TX · 314 Units', figure: 'Active · Target IRR 19–21%' },
  { image: aerial, name: 'The Warren', meta: 'Dallas, TX · 220 Units', figure: 'Active · Target IRR 19–21%' },
  { image: apartment, name: 'Sutton on Park Lane', meta: 'Dallas, TX · 196 Units', figure: 'Active · Target IRR 15.6%' },
  { image: towers, name: 'The Calvin', meta: 'Plano, TX · 167 Units', figure: 'Active · Target IRR 19–21%' },
  { image: skyline, name: 'Paxton at Lake Highlands', meta: 'Dallas, TX · 1031 Exchange', figure: 'Active · Target IRR 15.8%' },
  { image: aerial, name: 'The Chandler', meta: 'Dallas–Fort Worth, TX', figure: 'Active · Target IRR 15.31%' },
  { image: skyline, name: 'The Mirabel', meta: 'Grand Prairie, TX · 86 Units', figure: 'Active · Acquired 2022' },
  { image: towers, name: 'Beach at Bayshore', meta: 'Tampa, FL · 6 Units', figure: 'Full Cycle · 1.50x Multiple' },
];
---

<section class="block" id="portfolio">
  <div class="wrap">
    <SectionHead label="Track Record" />
    <div class="port-head">
      <h2 class="display display-2">Every number is a <em>closed deal.</em></h2>
    </div>
    <div class="feature">
      <div class="feature-img">
        <Image src={apartment} alt="The Landry, Arlington TX" widths={[720, 1080, 1600]} sizes="(max-width: 1100px) 100vw, 60vw" />
        <span class="tag">Featured — Active</span>
      </div>
      <div class="feature-body">
        <span class="meta">Arlington, Texas · Built 1983</span>
        <h3>The Landry</h3>
        <p>
          A 288-unit community acquired from a forced seller at a steep discount to comps — an
          expired rate cap and pending loan maturity created the opening; our balance sheet and
          lender relationships closed it.
        </p>
        <div class="feature-stats">
          <div><div class="n">288</div><div class="l">Units</div></div>
          <div><div class="n">21.64%</div><div class="l">Target IRR</div></div>
          <div><div class="n">2.45x</div><div class="l">Equity Multiple</div></div>
        </div>
      </div>
    </div>
    <div class="props">
      {
        highlights.map((prop) => (
          <div class="prop">
            <div class="ph">
              <Image src={prop.image} alt={prop.alt} widths={[480, 720]} sizes="(max-width: 760px) 100vw, 33vw" />
            </div>
            <div class="bd">
              <span class="meta">{prop.meta}</span>
              <h4>{prop.name}</h4>
              <p class="blurb">{prop.blurb}</p>
            </div>
          </div>
        ))
      }
    </div>
    <div class="prop-index">
      {
        index.map((prop) => (
          <div class="prop-row">
            <Image class="thumb" src={prop.image} alt="" widths={[160]} sizes="72px" />
            <h4>{prop.name}</h4>
            <span class="meta">{prop.meta}</span>
            <span class="fig">{prop.figure}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
