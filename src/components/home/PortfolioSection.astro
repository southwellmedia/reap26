---
/**
 * PortfolioSection
 * "Track Record" — homepage teaser for /track-record. Reads the `properties`
 * content collection (single source of truth, data verified against
 * reapcapital.com/track-record). Featured deal + three full-cycle highlight
 * cards linking into their case studies, then the interactive portfolio map
 * and a CTA into the full track record page.
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import SectionHead from './SectionHead.astro';
import PropertyMapSection from '@/components/map/PropertyMapSection.astro';
import { byOrder, statusLabel } from '@/lib/properties';

const properties = await getCollection('properties');
const featured = properties.find((p) => p.data.featured);
const highlights = properties.filter((p) => p.data.highlight).sort(byOrder);
---

<section class="block" id="portfolio">
  <div class="wrap">
    <SectionHead label="Track Record" />
    <div class="port-head">
      <h2 class="display display-2">Every number is a <em>closed deal.</em></h2>
    </div>
    {
      featured && (
        <div class="feature">
          <div class="feature-img">
            <Image
              src={featured.data.image}
              alt={featured.data.imageAlt}
              widths={[720, 1080, 1600]}
              sizes="(max-width: 1100px) 100vw, 60vw"
            />
            <span class="tag">Featured — Newest Acquisition</span>
          </div>
          <div class="feature-body">
            <span class="meta">
              {
                featured.data.submarket
                  ? `${featured.data.location} · ${featured.data.submarket}`
                  : featured.data.location
              }
            </span>
            <h3>{featured.data.name}</h3>
            <p>{featured.data.blurb}</p>
            {featured.data.featureStats && (
              <div class="feature-stats">
                {featured.data.featureStats.map((stat) => (
                  <div>
                    <div class="n">{stat.n}</div>
                    <div class="l">{stat.l}</div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      )
    }
    <div class="props">
      {
        highlights.map((prop) => {
          const body = (
            <>
              <div class="ph">
                <Image src={prop.data.image} alt={prop.data.imageAlt} widths={[480, 720]} sizes="(max-width: 760px) 100vw, 33vw" />
              </div>
              <div class="bd">
                <span class="meta">{statusLabel(prop)} · {prop.data.location}</span>
                <h4>{prop.data.name}</h4>
                <p class="blurb">{prop.data.blurb}</p>
                {prop.data.caseStudy && (
                  <span class="more">Read the Case Study <span aria-hidden="true">⟶</span></span>
                )}
              </div>
            </>
          );
          return prop.data.caseStudy ? (
            <a class="prop" href={`/track-record/${prop.id}`}>{body}</a>
          ) : (
            <div class="prop">{body}</div>
          );
        })
      }
    </div>
    <div style="margin-top:72px">
      <PropertyMapSection
        showSrList
        ctaHref="/track-record"
        ctaLabel="View the Full Track Record"
      />
    </div>
  </div>
</section>
