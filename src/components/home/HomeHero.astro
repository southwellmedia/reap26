---
/**
 * HomeHero
 * Full-bleed hero: background video over the aerial poster, olive scrim,
 * staggered load-in, and the stat ticker.
 */
import heroBg from '@/assets/reap/hero-aerial-olive.webp';
import { firmStats } from '@/config/stats.config';
---

<section class="hero" id="top">
  <video
    class="hero-bg"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={heroBg.src}
    aria-hidden="true"
  >
    <!-- poster-only on phones — the footage isn't worth cellular bytes under the scrim -->
    <source src="/videos/hero.mp4" type="video/mp4" media="(min-width: 761px)" />
  </video>
  <div class="hero-scrim"></div>
  <div class="wrap hero-in">
    <div class="kicker hload">
      <span class="eyebrow on-dark">Real Estate • Private Equity • Investing</span>
    </div>
    <h1 class="display hload hload-2">
      Creating generational wealth through<br /><em class="gold">passive investments</em>
    </h1>
    <div class="hero-row hload hload-3">
      <p>
        Reap Capital is an IRR-driven, vertically integrated, value-add operator. We purchase
        underperforming assets and increase their revenue by renovating, upgrading, repositioning,
        or improving the functionality of the asset.
      </p>
      <div class="hero-ctas">
        <a class="btn gold" href="/invest">Invest With Us <span aria-hidden="true">⟶</span></a>
        <a class="btn ghost" href="/track-record">View Track Record</a>
      </div>
    </div>
  </div>
  <div class="ticker hload hload-4">
    <div>
      <div class="n">{firmStats.avgIrr}</div>
      <div class="l">Average Realized IRR Since Inception</div>
    </div>
    <div>
      <div class="n">{firmStats.aum}</div>
      <div class="l">Assets Under Management</div>
    </div>
    <div>
      <div class="n">{firmStats.transactions}</div>
      <div class="l">Transactions Since {firmStats.transactionsSinceYear}</div>
    </div>
    <div>
      <div class="n">{firmStats.fullCycle}</div>
      <div class="l">Full-Cycle Investments</div>
    </div>
  </div>
</section>
