---
/**
 * ValuesSection
 * "Why We Do It" — three core values (distilled from the five on
 * reapcapital.com/about), each tied to operating proof rather than
 * standing as a bare adjective. Hairline-ruled grid mirroring the
 * dark panel's cols treatment.
 */
import SectionHead from './SectionHead.astro';
import { firmStats } from '@/config/stats.config';

const values = [
  {
    name: 'Discipline',
    body: `We adhere to our processes and strategy when making investment decisions — the same underwriting on all ${firmStats.transactions} transactions since ${firmStats.transactionsSinceYear}.`,
  },
  {
    name: 'Integrity',
    body: 'We stand by our morals and values even in the most difficult situations. The track record on this site is reported the way it landed — closed deals, not projections.',
  },
  {
    name: 'Loyalty',
    body: 'We are committed and dedicated to our investors, our colleagues, and our firm. Every member of this team has capital invested alongside yours.',
  },
];
---

<section class="block values-block">
  <div class="wrap">
    <SectionHead label="Why We Do It" />
    <div class="split split-end" style="margin-top:48px">
      <h2 class="display display-2">The compass for <em>every decision.</em></h2>
      <p class="side-note">
        Our core values are the fundamental beliefs we hold — the compass that guides the behavior
        of our people and our firm in every action and decision.
      </p>
    </div>
    <div class="values-grid">
      {
        values.map((value) => (
          <div>
            <h3>{value.name}</h3>
            <p>{value.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
